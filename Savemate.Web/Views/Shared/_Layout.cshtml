@using System.Security.Claims
@{
    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Savemate</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style> 
             
            .main-container {
                flex-grow: 1; /* This pushes the footer to the bottom */
                padding-top: 30px;
                padding-bottom: 30px;
                display: flex;
                flex-direction: column;
            }

            footer {
                height: 50px;
                display: flex;
                align-items: center;
                font-size: 0.9rem;
                background: #fff;
                flex-shrink: 0; /* Prevents the footer from squishing */
            }

            body {
                background-color: #f8f9fb;
            }

            .navbar {
                backdrop-filter: blur(8px);
            }

            .brand-logo {
                font-weight: 700;
                font-size: 1.3rem;
                letter-spacing: 0.5px;
            }

            .nav-link {
                font-weight: 500;
            }

                .nav-link:hover {
                    color: #0d6efd !important;
                }

            .avatar {
                width: 36px;
                height: 36px;
                font-weight: 600;
                border-radius: 50%;
            }

            .dropdown-menu {
                border-radius: 12px;
            }

            /* .main-container {
                padding-top: 30px;
                padding-bottom: 30px;
            }

            footer {
                font-size: 0.9rem;
                background: #fff;
            } */
    </style>
</head>

<body class="d-flex flex-column min-vh-100">

    <!-- 🔥 NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top">
        <div class="container">

            <!-- Logo -->
            <a class="navbar-brand brand-logo text-primary" asp-controller="Home" asp-action="Index">
                💰 Savemate
            </a>

            <!-- Toggle -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Nav Content -->
            <div class="collapse navbar-collapse" id="navbarContent">

                <!-- Left Links -->
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-speedometer2"></i>
                            @(User.Identity.IsAuthenticated ? "Dashboard" : "Home")
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Transaction" asp-action="Index">
                            <i class="bi bi-arrow-left-right"></i> Transactions
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Index">
                            <i class="bi bi-wallet2"></i> Accounts
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="Index">
                            <i class="bi bi-shield-lock"></i> Admin
                        </a>
                    </li>
                </ul>

                <!-- Right Side -->
                <ul class="navbar-nav">

                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item dropdown">

                            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2"
                                   href="#"
                                   data-bs-toggle="dropdown">

                                <div class="avatar bg-primary text-white d-flex align-items-center justify-content-center">
                                    @User.Identity.Name?.Substring(0, 1).ToUpper()
                                </div>

                                <span class="d-none d-lg-inline">@User.Identity.Name</span>
                            </a>

                            <ul class="dropdown-menu dropdown-menu-end shadow p-3">

                                <li class="text-center mb-2">
                                    <div class="avatar bg-primary text-white mx-auto d-flex align-items-center justify-content-center"
                                         style="width:60px; height:60px; font-size:22px;">
                                        @User.Identity.Name?.Substring(0, 1).ToUpper()
                                    </div>
                                </li>

                                <li class="text-center fw-semibold">
                                    @User.Identity.Name
                                </li>

                                <li class="text-center text-muted small mb-3">
                                    @User.FindFirst(ClaimTypes.Email)?.Value
                                </li>

                                <li>
                                    <a class="btn btn-outline-primary w-100 btn-sm mb-2"
                                           asp-controller="ApplicationUser"
                                           asp-action="Edit"
                                           asp-route-id="@userId">
                                        <i class="bi bi-pencil"></i> Edit Profile
                                    </a>
                                </li>

                                <li>
                                    <a class="btn btn-outline-danger w-100 btn-sm"
                                           asp-controller="Authentication"
                                           asp-action="Logout">
                                        <i class="bi bi-box-arrow-right"></i> Logout
                                    </a>
                                </li>
                            </ul>
                        </li>
                    }

                </ul>
            </div>
        </div>
    </nav>

    <!-- 🔥 MAIN CONTENT -->
    <div class="container main-container">
        <main class="flex-fill container main-container">
            @RenderBody()
        </main>
    </div>

    <!-- 🔥 FOOTER -->
    <footer class="border-top py-2 bg-white">
        <div class="container d-flex justify-content-between align-items-center">
            <span class="text-muted small">
                &copy; @DateTime.Now.Year Savemate
            </span>

            <a asp-controller="Home" asp-action="Privacy" class="text-decoration-none small">
                Privacy
            </a>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>