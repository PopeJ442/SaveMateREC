@model IEnumerable<Savemate.Application.ViewModels.TransactionViewModel>

@{
    ViewData["Title"] = "Transactions";
}

<h2>Transactions</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Add Transaction</a>
</p> 

<table class="table table-striped">

    <div asp-validation-summary="All" class="text-danger"></div>
    <thead>
        <tr>
            <th>Type</th>
            <th>Amount</th>
            <th>Date</th>
            <th>From Account</th>
            <th>To Account</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var t in Model)
        {
            <tr>
                <td>@t.Type</td>
                <td>@t.Amount.ToString("C")</td>
                <td>@t.Date.ToShortDateString()</td>
                <td>@t.FromAccountName</td>
                <td>@t.ToAccountName</td>
                <td>
                      <a asp-action="Details" asp-route-id="@t.Id" class="btn btn-sm btn-info">View</a>
                    @if (t.IsReversed == true || t.IsReversalEntry == true)
                    {
                        <button class="btn btn-danger" disabled>Reversed</button>
                    }
                    else
                    {
                        <form asp-action="ReverseConfirmed" method="post" style="display:inline">
                            <input type="hidden" name="id" value="@t.Id" />
                            <button type="submit" class="btn btn-sm btn-warning">Reverse</button>
                        </form>
                    }


                   @*  <a asp-action="Delete" asp-route-id="@t.Id" class="btn btn-sm btn-danger">Delete</a> *@
                </td>
            </tr>
        }
    </tbody>
</table>
