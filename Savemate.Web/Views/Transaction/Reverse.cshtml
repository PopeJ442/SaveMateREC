@model Savemate.Application.ViewModels.TransactionViewModel
@{
    ViewData["Title"] = "Edit Transaction";
}

<h2>Edit Transaction</h2>

<form asp-action="ReverseConfirmed" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label asp-for="Type"></label>
        <select asp-for="Type" class="form-control"
                asp-items="Html.GetEnumSelectList<Savemate.Domain.Enums.TransactionTypeEnum>()"></select>
    </div>

    <div class="form-group">
        <label asp-for="Amount"></label>
        <input asp-for="Amount" class="form-control" />
        <span asp-validation-for="Amount" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Date"></label>
        <input asp-for="Date" class="form-control" type="date" />
        <span asp-validation-for="Date" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Note"></label>
        <textarea asp-for="Note" class="form-control"></textarea>
        <span asp-validation-for="Note" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="FromAccountId"></label>
        <select asp-for="FromAccountId" asp-items="Model.Accounts" class="form-control">
            <option value="">-- Select From Account --</option>
        </select>
    </div>

    <div class="form-group">
        <label asp-for="ToAccountId"></label>
        <select asp-for="ToAccountId" asp-items="Model.Accounts" class="form-control">
            <option value="">-- Select To Account --</option>
        </select>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
