@model Savemate.Application.ViewModels.TransactionViewModel

@{
    ViewData["Title"] = "Create Transaction";
}

<h2 class="mb-3">Create Transaction</h2>

<form asp-action="Create" method="post">

    <div asp-validation-summary="All" class="text-danger"></div>
    <div class="card shadow-sm p-4">

        <div class="mb-3">
            <label asp-for="Type" class="form-label fw-bold">Transaction Type</label>
            <select asp-for="Type" class="form-select" id="transactionType">
                @foreach (var type in Enum.GetValues(typeof(Savemate.Domain.Enums.TransactionTypeEnum)))
                {
                    <option value="@type">@type</option>
                }
            </select>
            <span asp-validation-for="Type" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Amount" class="form-label fw-bold">Amount</label>
            <input asp-for="Amount" class="form-control" type="number" step="0.01" />
            <span asp-validation-for="Amount" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Date" class="form-label fw-bold">Date</label>
            <input asp-for="Date" class="form-control" type="date" />
            <span asp-validation-for="Date" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="FromAccountId" class="form-label fw-bold">From Account</label>
            <select asp-for="FromAccountId" asp-items="Model.Accounts" class="form-select" id="fromAccount">
                <option value="">-- Select Account --</option>
            </select>
            <span asp-validation-for="FromAccountId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="ToAccountId" class="form-label fw-bold">To Account</label>
            <select asp-for="ToAccountId" asp-items="Model.Accounts" class="form-select" id="toAccount">
                <option value="">-- Select Account --</option>
            </select>
            <span asp-validation-for="ToAccountId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Category" class="form-label fw-bold">Category Type</label>
            <select asp-for="Category" class="form-select">
                @foreach (var categoryType in Enum.GetValues(typeof(Savemate.Domain.Enums.CategoryTypeEnum)))
                {
                    <option value="@((int)categoryType)">@categoryType</option>
                }
            </select>
            <span asp-validation-for="Category" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Note" class="form-label fw-bold">Note</label>
            <textarea asp-for="Note" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Note" class="text-danger"></span>
        </div>

        <div class="text-end">
            <button type="submit" class="btn btn-primary px-4">Save</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>

    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        // === Prevent selecting the same account for both dropdowns ===
        const fromAccount = document.getElementById("fromAccount");
        const toAccount = document.getElementById("toAccount");

        fromAccount.addEventListener("change", function () {
            const selected = this.value;
            Array.from(toAccount.options).forEach(option => {
                option.disabled = option.value && option.value === selected;
            });
        });

        toAccount.addEventListener("change", function () {
            const selected = this.value;
            Array.from(fromAccount.options).forEach(option => {
                option.disabled = option.value && option.value === selected;
            });
        });

        // === Optional: Hide/show fields based on Transaction Type ===
        const typeSelect = document.getElementById("transactionType");
        const fromAccountDiv = document.querySelector('[asp-for="FromAccountId"]').closest('.mb-3');
        const toAccountDiv = document.querySelector('[asp-for="ToAccountId"]').closest('.mb-3');

        function toggleAccounts() {
            const type = typeSelect.value;

            // Expense: Show FromAccount only
            // Income: Show ToAccount only
            // Transfer: Show both
            if (type === "Expense") {
                fromAccountDiv.style.display = "block";
                toAccountDiv.style.display = "none";
            } else if (type === "Income") {
                fromAccountDiv.style.display = "none";
                toAccountDiv.style.display = "block";
            } else {
                fromAccountDiv.style.display = "block";
                toAccountDiv.style.display = "block";
            }
        }

        typeSelect.addEventListener("change", toggleAccounts);
        toggleAccounts(); // run on page load
    </script>
}
