@model Savemate.Application.ViewModels.TransactionViewModel

@{
    ViewData["Title"] = "Create Transaction";
}

<h2 class="mb-4 fw-bold">Create Transaction</h2>

<form asp-action="Create" method="post" class="needs-validation">
    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <div class="card shadow-sm p-4">

        <!-- Transaction Type -->
        <div class="mb-3">
            <label asp-for="Type" class="form-label fw-bold">Transaction Type</label>
            <select asp-for="Type" class="form-select" id="transactionType">
                @foreach (var type in Enum.GetValues(typeof(Savemate.Domain.Enums.TransactionTypeEnum)))
                {
                    <option value="@type">@type</option>
                }
            </select>
            <span asp-validation-for="Type" class="text-danger"></span>
        </div>

        <!-- Amount -->
        <div class="mb-3">
            <label asp-for="Amount" class="form-label fw-bold">Amount</label>
            <div class="input-group">
                <span class="input-group-text">GHS</span>
                <input asp-for="Amount" class="form-control" type="number" step="0.01" />
            </div>
            <span asp-validation-for="Amount" class="text-danger"></span>
        </div>

        <!-- From Account -->
        <div class="mb-3" id="fromAccountDiv">
            <label class="form-label fw-bold">From Account</label>
            <select asp-for="FromAccountId" asp-items="Model.Accounts" class="form-select" id="fromAccount">
                <option value="">-- Select Account --</option>
            </select>
            <small id="fromBalance" class="text-muted"></small>
        </div>

        <!-- To Account -->
        <div class="mb-3" id="toAccountDiv">
            <label class="form-label fw-bold">To Account</label>
            <select asp-for="ToAccountId" asp-items="Model.Accounts" class="form-select" id="toAccount">
                <option value="">-- Select Account --</option>
            </select>
            <small id="toBalance" class="text-muted"></small>
        </div>

        <!-- Category -->
        <div class="mb-3">
            <label asp-for="Category" class="form-label fw-bold">Category</label>
            <select asp-for="Category" class="form-select" id="categorySelect">
                @foreach (var categoryType in Enum.GetValues(typeof(Savemate.Domain.Enums.CategoryTypeEnum)))
                {
                    <option value="@((int)categoryType)">@categoryType</option>
                }
            </select>
            <span asp-validation-for="Category" class="text-danger"></span>
        </div>

        <!-- Note/Reference -->
        <div class="mb-3">
            <label asp-for="Note" class="form-label fw-bold">Reference</label>
            <textarea asp-for="Note" class="form-control" rows="3" placeholder="Optional note or description"></textarea>
            <span asp-validation-for="Note" class="text-danger"></span>
        </div>

        <!-- Buttons -->
        <div class="text-end">
            <button type="submit" class="btn btn-primary px-4">Save</button>
            <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
        </div>

    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        // Elements
        const fromAccount = document.getElementById("fromAccount");
        const toAccount = document.getElementById("toAccount");

        const typeSelect = document.getElementById("transactionType");
        const fromAccountDiv = document.getElementById("fromAccountDiv");
        const toAccountDiv = document.getElementById("toAccountDiv");

        // === Show / Hide Accounts Based on Type ===
        function toggleAccounts() {
            const type = typeSelect.value;

            if (type === "Expense") {
                fromAccountDiv.style.display = "block";
                toAccountDiv.style.display = "none";
            }
            else if (type === "Income") {
                fromAccountDiv.style.display = "none";
                toAccountDiv.style.display = "block";
            }
            else { // Transfer
                fromAccountDiv.style.display = "block";
                toAccountDiv.style.display = "block";
            }
        }

        typeSelect.addEventListener("change", toggleAccounts);
        toggleAccounts();

        // === Prevent selecting the same account ===
        function syncAccountDisabling() {
            const fromValue = fromAccount.value;
            const toValue = toAccount.value;

            Array.from(toAccount.options).forEach(option => {
                option.disabled = (option.value === fromValue);
            });

            Array.from(fromAccount.options).forEach(option => {
                option.disabled = (option.value === toValue);
            });
        }

        fromAccount.addEventListener("change", syncAccountDisabling);
        toAccount.addEventListener("change", syncAccountDisabling);
        syncAccountDisabling();

        // === Load Balance Preview ===
        function loadBalance(selectElement, labelElement) {
            const accountId = selectElement.value;

            if (!accountId) {
                labelElement.innerText = "";
                return;
            }

            fetch(`/Transaction/GetAccountBalance?accountId=${accountId}`)
                .then(response => response.json())
                .then(data => {
                    labelElement.innerText = `Balance: GHS ${data.balance.toFixed(2)}`;
                });
        }

        fromAccount.addEventListener("change", () => {
            loadBalance(fromAccount, document.getElementById("fromBalance"));
        });

        toAccount.addEventListener("change", () => {
            loadBalance(toAccount, document.getElementById("toBalance"));
        });

    </script>

}
