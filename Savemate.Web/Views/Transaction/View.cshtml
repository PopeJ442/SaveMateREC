@model Savemate.Application.ViewModels.TransactionViewModel
@{
    ViewData["Title"] = "Transaction Details";
}

<h2>Transaction Details</h2>

<table class="table table-bordered">
    <tr>
        <th>Type</th>
        <td>@Model.Type</td>
    </tr>
    <tr>
        <th>Amount</th>
        <td>@Model.Amount</td>
    </tr>
    <tr>
        <th>Date</th>
        <td>@Model.Date.ToShortDateString()</td>
    </tr>
    <tr>
        <th>Note</th>
        <td>@Model.Note</td>
    </tr>
    <tr>
        <th>From Account</th>
        <td>@Model.FromAccountName</td>
    </tr>
    <tr>
        <th>To Account</th>
        <td>@Model.ToAccountName</td>
    </tr>
</table>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back</a>
