@model Savemate.Application.ViewModels.TransactionViewModel

@{
    ViewData["Title"] = "Transaction Details";
}

<h2 class="mb-4">Transaction Details</h2>

<div class="card p-4">
    <dl class="row">

        <dt class="col-sm-3">Transaction Type</dt>
        <dd class="col-sm-9">@Model.Type</dd>

        <dt class="col-sm-3">Amount</dt>
        <dd class="col-sm-9">GHS @Model.Amount</dd>

        <dt class="col-sm-3">Description</dt>
        <dd class="col-sm-9">@Model.Note</dd>

        <dt class="col-sm-3">Date</dt>
        <dd class="col-sm-9">@Model.Date.ToString("MMMM dd, yyyy hh:mm tt")</dd>

        @if (Model.FromAccountId != null)
        {
            <dt class="col-sm-3">From Account</dt>
            <dd class="col-sm-9">@Model.FromAccountName</dd>
        }
       
        
        
        @if (Model.ToAccountId != null)
        {
            <dt class="col-sm-3">To Account</dt>
            <dd class="col-sm-9">@Model.ToAccountName</dd>
        }
        <dt class="col-sm-3">IsReversed</dt>
        <dd class="col-sm-9">  @Model.IsReversed</dd>

        <dt class="col-sm-3">IsReversalEntry</dt>
        <dd class="col-sm-9">@Model.IsReversalEntry</dd>
    </dl>

    <a asp-action="Index" class="btn btn-secondary mt-3">Back to List</a>
</div>
