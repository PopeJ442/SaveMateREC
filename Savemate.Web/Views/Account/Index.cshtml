@model IEnumerable<Savemate.Web.ViewModels.AccountViewModel>

@{
    ViewData["Title"] = "Accounts";
}

<h2>Accounts</h2>

<p>
    <a asp-action="CreateAccount" class="btn btn-primary">+ Create New Account</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(m => m.First().Name)</th>
            <th>@Html.DisplayNameFor(m => m.First().Type)</th>
            <th>@Html.DisplayNameFor(m => m.First().InitialBalance)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var account in Model)
        {
            <tr>
                <td>@account.Name</td>
                <td>@account.Type</td>
                <td>@account.InitialBalance.ToString("C")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@account.Id" class="btn btn-sm btn-warning">Edit</a>
                   @*  <a asp-action="DeleteAccount" asp-route-id="@account.Id" class="btn btn-sm btn-danger">Delete</a> *@
                    <form asp-action="DeleteAccount" asp-route-id="@account.Id" method="post"
                          onsubmit="return confirm('Are you sure you want to delete this account?');"
                          style="display:inline;">
                        <input type="hidden" name="id" value="@account.Id" />
                        <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
